{
  "For Range": {
    "prefix": "range",
    "body": "for ${1:k}, ${2:v} := range ${3:collection} {\n\t$0\n}",
    "description": "for range loop"
  },

  "For Index": {
    "prefix": "fori",
    "body": "for ${1:i} := 0; ${1:i} < ${2:n}; ${1:i}++ {\n\t$0\n}",
    "description": "for loop con índice"
  },

  "Switch": {
    "prefix": "sw",
    "body": "switch ${1:variable} {\ncase ${2:value}:\n\t$0\ndefault:\n}",
    "description": "switch statement"
  },

  "Select Channels": {
    "prefix": "sel",
    "body": "select {\ncase ${1:v} := <-${2:ch1}:\n\t$0\ncase ${3:ch3} <- ${4:v}:\n}",
    "description": "select con channels"
  },

  "Struct": {
    "prefix": "st",
    "body": "type ${1:Name} struct {\n\t${2:Field} ${3:Type}\n}",
    "description": "type struct"
  },

  "Struct + Constructor": {
    "prefix": "stc",
    "body": "type ${1:Name} struct {\n\t${2:field} ${3:Type}\n}\n\nfunc New${1:Name}(${2:field} ${3:Type}) *${1:Name} {\n\treturn &${1:Name}{\n\t\t${2:field}: ${2:field},\n\t}\n}",
    "description": "struct con constructor New..."
  },

  "Interface": {
    "prefix": "iface",
    "body": "type ${1:Name} interface {\n\t${2:Method}(${3:args}) ${4:ReturnType}\n}",
    "description": "type interface"
  },

  "Function": {
    "prefix": "fn",
    "body": "func ${1:Name}(${2:args}) ${3:ReturnType} {\n\t$0\n}",
    "description": "función básica"
  },

  "Method": {
    "prefix": "meth",
    "body": "func (${1:r} *${2:Receiver}) ${3:Name}(${4:args}) ${5:ReturnType} {\n\t$0\n}",
    "description": "método sobre un tipo"
  },

  "Main": {
    "prefix": "main",
    "body": "package main\n\nimport \"fmt\"\n\nfunc main() {\n\t$0\n}",
    "description": "package main + func main"
  },

  "Init": {
    "prefix": "init",
    "body": "func init() {\n\t$0\n}",
    "description": "func init()"
  },

  "If Error Return": {
    "prefix": "ife",
    "body": "if err != nil {\n\treturn ${1:nil}, err\n}",
    "description": "if err != nil { return }"
  },

  "If Error Wrap": {
    "prefix": "errw",
    "body": "if err != nil {\n\treturn ${1:nil}, fmt.Errorf(\"${2:context}: %w\", err)\n}",
    "description": "if err != nil con fmt.Errorf wrap"
  },

  "Errors New": {
    "prefix": "errt",
    "body": "errors.New(\"${1:message}\")",
    "description": "errors.New(...)"
  },

  "Goroutine": {
    "prefix": "gor",
    "body": "go func() {\n\t$0\n}()",
    "description": "goroutine anónima"
  },

  "Channel Make": {
    "prefix": "ch",
    "body": "${1:ch} := make(chan ${2:Type}${3:, bufferSize})",
    "description": "make(chan Type)"
  },

  "Mutex": {
    "prefix": "mu",
    "body": "var ${1:mu} sync.Mutex\n${1:mu}.Lock()\ndefer ${1:mu}.Unlock()\n$0",
    "description": "sync.Mutex con Lock/Unlock"
  },

  "WaitGroup": {
    "prefix": "wg",
    "body": "var ${1:wg} sync.WaitGroup\n${1:wg}.Add(${2:1})\ngo func() {\n\tdefer ${1:wg}.Done()\n\t$0\n}()\n${1:wg}.Wait()",
    "description": "sync.WaitGroup"
  },

  "Test Function": {
    "prefix": "test",
    "body": "func Test${1:Name}(t *testing.T) {\n\t$0\n}",
    "description": "func TestXxx(t *testing.T)"
  },

  "Benchmark": {
    "prefix": "bench",
    "body": "func Benchmark${1:Name}(b *testing.B) {\n\tfor i := 0; i < b.N; i++ {\n\t\t$0\n\t}\n}",
    "description": "func BenchmarkXxx(b *testing.B)"
  },

  "Table Test Cases": {
    "prefix": "tcase",
    "body": "tests := []struct {\n\tname  string\n\tinput ${1:Type}\n\twant  ${2:Type}\n}{\n\t{\"${3:caso1}\", ${4:input}, ${5:want}},\n}\nfor _, tt := range tests {\n\tt.Run(tt.name, func(t *testing.T) {\n\t\tgot := ${6:funcion}(tt.input)\n\t\tif got != tt.want {\n\t\t\tt.Errorf(\"got %v, want %v\", got, tt.want)\n\t\t}\n\t})\n}",
    "description": "tabla de test cases"
  },

  "HTTP Handler": {
    "prefix": "hh",
    "body": "func ${1:Name}Handler(w http.ResponseWriter, r *http.Request) {\n\t$0\n}",
    "description": "http.HandlerFunc"
  },

  "Middleware": {
    "prefix": "mid",
    "body": "func ${1:Name}Middleware(next http.Handler) http.Handler {\n\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\t$0\n\t\tnext.ServeHTTP(w, r)\n\t})\n}",
    "description": "middleware http"
  },

  "Log Printf": {
    "prefix": "log",
    "body": "log.Printf(\"${1:message}: %v\\n\", ${2:value})",
    "description": "log.Printf"
  },

  "Defer": {
    "prefix": "def",
    "body": "defer ${1:func}()",
    "description": "defer statement"
  },

  "Make Slice": {
    "prefix": "msl",
    "body": "${1:name} := make([]${2:Type}, ${3:0}, ${4:cap})",
    "description": "make slice con len y cap"
  },

  "Make Map": {
    "prefix": "mmap",
    "body": "${1:name} := make(map[${2:KeyType}]${3:ValueType})",
    "description": "make map"
  }
}